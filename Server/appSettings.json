{
  "RunJanusServer": true,
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=./configuration.db"
  },
  "JanusConfiguration": {
    "HostName": "lte-rc.northeurope.cloudapp.azure.com",
    "UdpPortRangeStart": 10000,
    "UdpPortRangeEnd": 10200,
    "TcpPortRangeStart": 11000,
    "TcpPortRangeEnd": 11200
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "LteCar.Server.Hubs": "Debug",
      "LteCar.Server.Services": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}