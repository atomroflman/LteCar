{
  "pinManagers": {
    "Pca9685": {
      "type": "Pca9685PwmExtension",
      "options": {
        "boardAddress": 0,
        "i2cBus": 1
      }
    }
  },
  "controlChannels": {
    "steer": {
      "pinManager": "Pca9685",
      "testDisabled": true,
      "address": 14,
      "controlType": "Steering"
    },
    "throttle": {
      "pinManager": "Pca9685",
      "address": 1,
      "controlType": "Throttle",
      "testDisabled": true
    },
    "gearDown": {
      "controlType": "GearShift",
      "testDisabled": true,
      "options": {
        "shiftDirection": "down"
      }
    },
    "gearUp": {
      "controlType": "GearShift",
      "testDisabled": true,
      "options": {
        "shiftDirection": "up"
      }
    },
    "headWarningLight": {
      "controlType": "RotaryLight",
      "pinManager": "Pca9685",
      "address": 15
    },
    "rightTurnLight": {
      "controlType": "PwmBlinker",
      "pinManager": "Pca9685",
      "address": 11,
      "options": {
        "blinkCycleMs": 500
      }
    },
    "leftTurnLight": {
      "controlType": "PwmBlinker",
      "pinManager": "Pca9685",
      "address": 10,
      "options": {
        "blinkCycleMs": 500
      }
    }
  },
  "videoStreams": {
    "mainCamera": {
      "name": "Main Camera",
      "description": "Primary vehicle camera for navigation and monitoring",
      "type": "camera",
      "location": "front",
      "enabled": true,
      "priority": 1
    },
    "rearCamera": {
      "name": "Rear Camera",
      "description": "Rear view camera for backing assistance",
      "type": "camera",
      "location": "rear",
      "enabled": false,
      "priority": 2
    }
  },
  "telemetryChannels": {
    "lifetime": {
      "telemetryType": "LteCar.Onboard.Telemetry.ApplicationLifetimeReader"
    },
    "battery": {
      "telemetryType": "LteCar.Onboard.Telemetry.JbdBmsTelemetryReader",
      "readIntervalTicks": 50,
      "options": {
        "jbdToolPath": "~/ltecar/bin/jbdtools",
        "channel": "A5:C2:37:55:36:B6"
      }
    }
  },
  "videoStreams": {
    "main": {
      "streamId": "main",
      "enabled": true,
      "videoSettings": {
        "width": 1280,
        "height": 720,
        "framerate": 30,
        "bitrate": 2500000,
        "brightness": 0
      },
      "protocol": "UDP",
      "purpose": "main_camera",
      "codec": "vp8",
      "options": {
        "cameraDevice": "/dev/video0",
        "cameraType": "libcamera-vid"
      }
    },
    "secondary": {
      "streamId": "secondary",
      "enabled": false,
      "videoSettings": {
        "width": 640,
        "height": 480,
        "framerate": 22,
        "bitrate": 1500000,
        "brightness": 0
      },
      "protocol": "UDP",
      "purpose": "rear_camera",
      "codec": "vp8",
      "options": {
        "cameraDevice": "/dev/video1",
        "cameraType": "libcamera-vid"
      }
    },
    "low_res": {
      "streamId": "low_res",
      "enabled": true,
      "videoSettings": {
        "width": 320,
        "height": 240,
        "framerate": 15,
        "bitrate": 500000,
        "brightness": 0
      },
      "protocol": "UDP",
      "purpose": "telemetry_overlay",
      "codec": "vp8",
      "options": {
        "cameraDevice": "/dev/video0",
        "cameraType": "libcamera-vid"
      }
    }
  }
}